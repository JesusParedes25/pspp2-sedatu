# ─── Base de datos ──────────────────────────────────────────────
DB_NAME=pspp_db
DB_USER=pspp_user
DB_PASSWORD=cambiar_en_produccion

# ─── JWT ────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_secreto_generado_con_el_comando_de_arriba
JWT_EXPIRES_IN=8h

# ─── MinIO ──────────────────────────────────────────────────────
MINIO_USER=pspp_admin
MINIO_PASSWORD=cambiar_en_produccion
MINIO_BUCKET=pspp-evidencias

# ─── GeoServer ──────────────────────────────────────────────────
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=cambiar_en_produccion

# ─── Frontend ───────────────────────────────────────────────────
# URL pública donde vive el frontend. Se usa para construir links de
# invitación/activación de cuenta (?token=...) enviados por correo o
# copiados manualmente. En desarrollo: http://localhost:5173
# En producción: la URL real del dominio (ej. https://daot.geobint.com) —
# si se deja vacío, el backend cae a localhost:5173 y los links de
# activación quedarán rotos para cualquiera fuera de esa máquina.
FRONTEND_URL=http://localhost:5173

# ─── SMTP (dejar vacío si no está configurado aún) ───────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sedatu.gob.mx
