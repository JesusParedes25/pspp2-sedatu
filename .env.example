# ─── Base de datos ──────────────────────────────────────────────
DB_NAME=pspp_db
DB_USER=pspp_user
DB_PASSWORD=cambiar_en_produccion

# ─── JWT ────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_secreto_generado_con_el_comando_de_arriba
JWT_EXPIRES_IN=8h

# ─── MinIO ──────────────────────────────────────────────────────
MINIO_USER=pspp_admin
MINIO_PASSWORD=cambiar_en_produccion
MINIO_BUCKET=pspp-evidencias

# ─── GeoServer ──────────────────────────────────────────────────
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=cambiar_en_produccion

# ─── SMTP (dejar vacío si no está configurado aún) ───────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sedatu.gob.mx
